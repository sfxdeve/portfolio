{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm validate:content && vite build",
    "build:vercel": "NITRO_PRESET=vercel pnpm build",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test:unit && pnpm test:e2e && pnpm build",
    "clean": "rm -rf .output .tanstack .vinxi dist dist-ssr coverage playwright-report test-results node_modules/.vite node_modules/.nitro",
    "dev": "vite dev --port 3000",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware",
    "preview": "vite preview --port 4173",
    "routes:gen": "tsr generate",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "validate:content": "vitest run tests/content"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@gsap/react": "^2.1.2",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/router-cli": "^1.167.18",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "nitro": "^3.0.260610-beta",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "shadcn": "^4.13.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.9.0 <12"
  },
  "packageManager": "pnpm@11.9.0"
}
