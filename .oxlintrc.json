{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "react", "jsx-a11y"],
  "options": {
    "typeAware": true
  },
  "ignorePatterns": [".agents/**", "src/routeTree.gen.ts"],
  "rules": {
    "react/react-in-jsx-scope": "off"
  }
}
